# Copy this file to .env and fill in your values

# Optional: Google account email (only needed if you want auto-login)
# The recommended flow is to leave these blank and log in manually
# on first launch — the browser session will be saved to ./auth/
GF_EMAIL=
GF_PW=

# Groww API is used to resolve ISIN codes → NSE ticker symbols.
# No API key needed — it's a public endpoint.

# Server settings
HOST=127.0.0.1
PORT=8000
